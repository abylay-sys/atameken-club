# ───────── Server ─────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5500,https://your-tilda-domain.tilda.ws,https://cabinet.your-domain.kz

# Emails модераторов через запятую (могут пользоваться /admin/*)
ADMIN_EMAILS=admin@atameken.kz

# ───────── Database (Neon) ─────────
# Получи здесь: https://console.neon.tech → Project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ───────── Auth ─────────
# Любые длинные случайные строки. Сгенерируй: openssl rand -hex 64
JWT_ACCESS_SECRET="replace-with-64-hex-chars"
JWT_REFRESH_SECRET="replace-with-another-64-hex-chars"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ───────── Telegram ─────────
# 1) Создай бота через @BotFather → /newbot → получи токен
# 2) Создай группу модераторов, добавь бота
# 3) Узнай chat_id: добавь в группу @getmyid_bot или посмотри https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MODERATOR_CHAT_ID=""

# ───────── Google Sheets ─────────
# 1) https://console.cloud.google.com → создай проект → включи Google Sheets API
# 2) Создай Service Account → скачай JSON-ключ
# 3) Открой свою таблицу → Поделиться → добавь client_email из JSON как Editor
# 4) Вставь сюда всё содержимое JSON одной строкой (важно: экранируй кавычки или используй base64 ниже)
# 5) GOOGLE_SHEET_ID = часть URL между /d/ и /edit
GOOGLE_SHEET_ID=""
# Вариант A: полный JSON как строка (многострочный не работает в .env — используй вариант B)
# Вариант B (рекомендую): закодируй JSON в base64 и вставь сюда:
#   macOS:   cat service-account.json | base64 | pbcopy
GOOGLE_SERVICE_ACCOUNT_BASE64=""
