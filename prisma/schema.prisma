generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SEEKER
  INVESTOR
  FRANCHISE
  SALE
  FRANCHISER
  FRANCHISEE
  BIZ_SELLER
  BIZ_BUYER
  GOODS_SELLER
  GOODS_BUYER
}

enum ProfileStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          UserRole
  emailVerified Boolean        @default(false)
  fullName      String?
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       CompanyProfile?
  refreshTokens RefreshToken[]
  publications  Publication[]
  favorites     Favorite[]
  complaintsFiled Complaint[]   @relation("ComplaintReporter")
  wallet        TokenWallet?
  purchasedCards PurchasedCard[]

  @@index([email])
}

model CompanyProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String
  bin           String?
  industry      String?
  region        String?
  description     String?  // короткая выжимка для публичного каталога
  descriptionFull String?  // полное описание (видно только админам)
  recommendation  String?  // рекомендация бизнес-клуба / Ассоциации / Союза / ОЮЛ
  website       String?
  instagram     String?
  facebook      String?
  linkedin      String?
  telegram      String?
  whatsapp      String?
  foundedYear   Int?
  revenue       String?
  employees     String?
  investmentNeed String?
  investmentGoal String?

  contactName   String?
  contactPhone  String?
  contactEmail  String?

  status        ProfileStatus @default(DRAFT)
  submittedAt   DateTime?
  verifiedAt    DateTime?
  rejectedReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

enum PublicationType {
  INVEST_PROJECT     // Соискатели инвестиций
  FRANCHISE          // Франчайзеры
  BUSINESS_FOR_SALE  // Продавцы готового бизнеса
  GOODS              // Продавцы товаров и сырья
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  REMOVED
}

model Publication {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        PublicationType
  status      PublicationStatus @default(PUBLISHED)

  // Денормализованные поля для каталога — индексируются для быстрого фильтра
  title       String
  industry    String?
  region      String?
  // Краткое описание для «короткой» карточки Реестра
  shortDesc   String?
  // Цена / паушал / мин. чек — текстом, формат свободный
  priceLabel  String?
  // Полный набор полей формы (4 типа разные) — храним как JSON
  data        Json

  publishedAt DateTime?         @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  favorites      Favorite[]
  complaints     Complaint[]
  purchasedBy    PurchasedCard[]

  @@index([userId])
  @@index([type, status])
  @@index([publishedAt])
}

// «Избранное» — звёздочка в карточке Реестра. Один user может добавить одну
// публикацию только один раз (composite unique key).
model Favorite {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, publicationId])
  @@index([userId])
  @@index([publicationId])
}

enum TokenTransactionType {
  PURCHASE     // купил пакет токенов
  SPEND_CARD   // открыл развёрнутую карточку
  SPEND_VERIF  // открыл результат верификации
  REFUND       // возврат
  BONUS        // бонус от админа / промокод
}

model TokenWallet {
  id           String             @id @default(cuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Int                @default(0)
  totalEarned  Int                @default(0)
  totalSpent   Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  transactions TokenTransaction[]
}

model TokenTransaction {
  id           String               @id @default(cuid())
  walletId     String
  wallet       TokenWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type         TokenTransactionType
  amount       Int                  // знаковый: +N пополнение, -N трата
  balanceAfter Int                  // снимок баланса после транзакции
  meta         Json?                // {packageSize}/{publicationId} и пр.
  createdAt    DateTime             @default(now())

  @@index([walletId])
  @@index([type])
}

// Учёт оплаченных «Развёрнутых карточек» — чтобы при повторном открытии
// не списывать токены дважды.
model PurchasedCard {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  tokensSpent   Int         @default(1)
  purchasedAt   DateTime    @default(now())

  @@unique([userId, publicationId])
  @@index([userId])
}

enum ComplaintStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// «Подать жалобу» из карточки Реестра. Модератор смотрит OPEN жалобы и
// решает: пометить публикацию REMOVED / снять жалобу / отправить запрос
// пользователю.
model Complaint {
  id            String          @id @default(cuid())
  publicationId String
  publication   Publication     @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  reporterId    String?         // null = аноним (если не залогинен — пока не разрешаем, но поле опциональное)
  reporter      User?           @relation("ComplaintReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reason        String          // короткое описание/причина
  details       String?         // дополнительные детали (опционально)
  status        ComplaintStatus @default(OPEN)
  resolution    String?         // комментарий модератора при закрытии
  createdAt     DateTime        @default(now())
  resolvedAt    DateTime?

  @@index([publicationId])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}
