generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SEEKER
  INVESTOR
  FRANCHISE
  SALE
}

enum ProfileStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          UserRole
  emailVerified Boolean        @default(false)
  fullName      String?
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       CompanyProfile?
  refreshTokens RefreshToken[]

  @@index([email])
}

model CompanyProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String
  bin           String?
  industry      String?
  region        String?
  description   String?
  website       String?
  foundedYear   Int?
  revenue       String?
  employees     String?
  investmentNeed String?
  investmentGoal String?

  contactName   String?
  contactPhone  String?
  contactEmail  String?

  status        ProfileStatus @default(DRAFT)
  submittedAt   DateTime?
  verifiedAt    DateTime?
  rejectedReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}
